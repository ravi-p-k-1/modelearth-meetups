# GitHub user or organization that owns the target repo.
# Example: modelearth
GITHUB_OWNER=

# Target repo where reviewed issues may eventually be created.
# Example: modelearth-meetups
GITHUB_REPO=

# GitHub Project URL linked to the repo.
# Example: https://github.com/orgs/modelearth/projects/3
GITHUB_PROJECT=

# GitHub personal access token or app token.
# Leave blank unless running code that talks to the GitHub API.
# Example format: github_pat_...
GITHUB_TOKEN=

# Folder containing transcripts in <date>/<source>/transcript.txt format.
# Example: transcripts/2026-06-11/otter/transcript.txt
TRANSCRIPTS_DIR=transcripts

# Folder where agent markdown and JSON outputs are written.
# Example: outputs/2026-06-11/otter/gpt-5.md
OUTPUTS_DIR=outputs

# Manifest file that tracks already processed transcripts.
PROCESSED_MANIFEST_PATH=processed-manifest.json
